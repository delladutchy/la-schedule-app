# ---------------------------------------------------------------------------
# REQUIRED — Google OAuth (produced by `npm run google:auth`)
# ---------------------------------------------------------------------------

# OAuth 2.0 Client ID from Google Cloud Console (Desktop app type).
GOOGLE_CLIENT_ID=

# OAuth 2.0 Client secret from the same client.
GOOGLE_CLIENT_SECRET=

# Long-lived refresh token produced by the one-time auth flow.
# Treat this like a password — it gives read-only access to your calendar.
GOOGLE_REFRESH_TOKEN=

# ---------------------------------------------------------------------------
# REQUIRED — which calendars count as "blockers"
# ---------------------------------------------------------------------------
# Comma-separated list of Google Calendar IDs. ONLY these calendars are
# used to compute busy time. Everything else (birthdays, personal, tasks) is
# ignored. Use "primary" for your main calendar, or the full id shown in
# Google Calendar → Settings → [calendar] → "Integrate calendar" → Calendar ID.
#
# Example:
#   BLOCKER_CALENDAR_IDS=primary,abcd1234@group.calendar.google.com
BLOCKER_CALENDAR_IDS=

# Optional per-calendar display mode overrides:
# - details: show job/event details (default)
# - private: show only "Unavailable" (hide event titles)
#
# Format:
#   CALENDAR_DISPLAY_MODES=primary:details,abcd1234@group.calendar.google.com:private
# You can also use "=" as separator per entry:
#   CALENDAR_DISPLAY_MODES=primary=details,abcd1234@group.calendar.google.com=private
# CALENDAR_DISPLAY_MODES=

# ---------------------------------------------------------------------------
# REQUIRED — admin access token
# ---------------------------------------------------------------------------
# Used to gate /admin and POST /api/sync. Must be >= 16 chars.
# Generate with: `openssl rand -hex 32`
ADMIN_TOKEN=

# ---------------------------------------------------------------------------
# OPTIONAL
# ---------------------------------------------------------------------------

# Netlify Blobs store name. Default is fine unless you want multiple sites
# sharing a single Netlify account without key collisions.
# BLOBS_STORE_NAME=availability-snapshots
